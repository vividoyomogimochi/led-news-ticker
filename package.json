{
  "name": "news-led-board",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:atlas": "node scripts/build-font-atlas.mjs",
    "gen:thumbs": "node scripts/gen-theme-thumbnails.mjs",
    "build": "tsc && tsc -p tsconfig.node.json && vite build",
    "preview": "vite preview",
    "deploy": "pnpm run build && wrangler pages deploy dist",
    "lint": "eslint src *.config.ts",
    "format": "prettier --write src *.config.ts",
    "format:check": "prettier --check src *.config.ts",
    "test": "vitest run"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["canvas", "workerd"]
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260312.1",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.4.0",
    "canvas": "^3.2.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "wrangler": "^4.72.0"
  }
}
