{
  "name": "news-led-board",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:atlas": "node scripts/build-font-atlas.mjs",
    "gen:thumbs": "node scripts/gen-theme-thumbnails.mjs",
    "build": "tsc && tsc -p tsconfig.node.json && vite build && cp node_modules/@resvg/resvg-wasm/index_bg.wasm dist/resvg.wasm",
    "dev:pages": "pnpm build && wrangler pages dev dist",
    "preview": "vite preview",
    "deploy": "pnpm run build && wrangler pages deploy dist",
    "lint": "eslint src *.config.ts",
    "format": "prettier --write src *.config.ts",
    "format:check": "prettier --check src *.config.ts",
    "test": "vitest run",
    "ws-test-server": "node scripts/ws-test-server.mjs",
    "sse-test-server": "node scripts/sse-test-server.mjs"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "canvas",
      "workerd"
    ]
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260312.1",
    "@eslint/js": "^10.0.1",
    "@resvg/resvg-wasm": "^2.6.2",
    "@types/node": "^25.4.0",
    "@types/ws": "^8.18.1",
    "canvas": "^3.2.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^28.1.0",
    "marked": "^17.0.4",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "wrangler": "^4.72.0",
    "ws": "^8.19.0"
  }
}
